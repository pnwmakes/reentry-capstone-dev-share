rules_version = '2';

// Craft rules based on data in your Firestore database
// Allow authenticated users to upload files to their own folders
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read and write files in their user_uploads folder
    match /user_uploads/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow public read access to uploaded files (for displaying images)
    // but only authenticated users can upload
    match /user_uploads/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Alternative: More permissive rules for development (use with caution)
    // match /{allPaths=**} {
    //   allow read, write: if request.auth != null;
    // }
  }
}